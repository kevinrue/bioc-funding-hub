{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Funding Opportunity",
  "type": "object",
  "required": [
    "title", "slug", "funder", "deadline_type", "currency",
    "eligibility_notes", "url", "categories", "status"
  ],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "funder": { "type": "string", "minLength": 1 },
    "program": { "type": "string" },
    "deadline": { "type": ["string", "null"], "format": "date" },
    "deadline_type": { "type": "string", "enum": ["fixed", "rolling", "estimated"] },
    "amount_min": { "type": ["number", "null"], "minimum": 0 },
    "amount_max": { "type": ["number", "null"], "minimum": 0 },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "eligibility_notes": { "type": "string", "minLength": 1 },
    "url": { "type": "string", "format": "uri" },
    "topics": { "type": "array", "items": { "type": "string" } },
    "categories": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "status": { "type": "string", "enum": ["open", "closed", "archived"] },
    "submitted_records": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
